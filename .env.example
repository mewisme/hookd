PORT=8080
CONFIG_PATH=/config/workflows.yaml

# Public origin of this service (no trailing slash).
# PUBLIC_URL=https://hooks.example.com

# From Resend dashboard → Webhooks → signing secret (whsec_...)
RESEND_WEBHOOK_SECRET=whsec_xxxxx

# Full Discord incoming webhook URL (Channel Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# Optional (workflows.example.yaml)
# ALERT_TOKEN=
# PARTNER_SECRET=
